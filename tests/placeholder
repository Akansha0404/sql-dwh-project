--silver.erp_loc_a101

SELECT 
REPLACE(cid,'-','') AS cid,
CASE
	WHEN TRIM(cntry) IN ('US', 'USA') THEN 'United States'
	WHEN TRIM(cntry) IN ('DE') THEN 'Germany'
	WHEN TRIM(cntry) IS NULL OR TRIM(cntry ='' THEN 'N/A'
	ELSE TRIM(cntry)
	END AS cntry
FROM bronze.erp_loc_a101

SELECT DISTINCT(cntry) FROM bronze.erp_loc_a101


